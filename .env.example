# Environment Variables for Instrument Scanner

# Hyperbolic API Key for OCR (required)
# Get yours at: https://app.hyperbolic.xyz/
HYPERBOLIC_API_KEY=your_hyperbolic_api_key_here

# Authentication Token Secret (required in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=your_secret_token_here

# Password for accessing the app (required in production)
# IMPORTANT: Change this to a secure password!
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
AUTH_PASSWORD=change-me-in-production

# Optional: OpenRouter API key (fallback OCR provider)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: Netlify Blobs usage stats
# NETLIFY_SITE_ID=your_netlify_site_id_here
# NETLIFY_BLOBS_TOKEN=your_netlify_blobs_token_here
