# === OCR Providers ===

# Hyperbolic API Key – primær OCR-udbyder (Pixtral-12B-2409)
HYPERBOLIC_API_KEY=your_hyperbolic_api_key_here

# OpenRouter API Key – valgfri fallback OCR-udbyder (Gemini 2.5 Flash Lite)
# Bruges automatisk hvis Hyperbolic fejler eller returnerer tomt svar
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# === OCR Provider Konfiguration (valgfri) ===

# Hvilken udbyder der bruges som primær: hyperbolic eller openrouter (standard: hyperbolic)
# OCR_PRIMARY_PROVIDER=hyperbolic

# Hvilken udbyder der bruges som fallback (standard: openrouter)
# OCR_FALLBACK_PROVIDER=openrouter

# Kommasepareret liste af modeller til Hyperbolic (standard: mistralai/Pixtral-12B-2409)
# HYPERBOLIC_OCR_MODELS=mistralai/Pixtral-12B-2409

# Kommasepareret liste af modeller til OpenRouter (standard: google/gemini-2.5-flash-lite)
# OPENROUTER_OCR_MODELS=google/gemini-2.5-flash-lite

# HTTP-Referer header til OpenRouter (valgfri, standard: URL)
# OPENROUTER_HTTP_REFERER=https://yourdomain.com

# App-navn vist i OpenRouter dashboard (valgfri)
# OPENROUTER_APP_NAME=instrumentskanner

# === Autentifikation ===

# Delt adgangskode til app-login
# AUTH_PASSWORD=your_shared_password_here

# Hemmelighed til session-tokens (brug en lang tilfældig streng i produktion)
# Generer med: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=your_secret_token_here

# === CORS ===

# Tilladte CORS-origins, kommasepareret (valgfri)
# Netlify-URLs tilføjes automatisk via URL, DEPLOY_PRIME_URL, DEPLOY_URL
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# === Brug-statistik (Netlify Blobs) ===

# Kræves for at gemme månedlig OCR-brug på tværs af funktions-instanser
# Find Site ID i Netlify dashboard → Site settings → General
# NETLIFY_SITE_ID=your_netlify_site_id_here

# Netlify personal access token (eller deploy token med blobs-adgang)
# NETLIFY_BLOBS_TOKEN=your_netlify_blobs_token_here
