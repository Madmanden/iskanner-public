# === OCR Providers ===

# OpenRouter API Key - primary OCR provider (Gemini 2.5 Flash Lite)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional Hyperbolic API Key - fallback OCR provider
# Requires a currently available Hyperbolic vision-language model.
# HYPERBOLIC_API_KEY=your_hyperbolic_api_key_here

# === OCR Provider Configuration (optional) ===

# Which provider to use first: openrouter or hyperbolic (default: openrouter)
# OCR_PRIMARY_PROVIDER=openrouter

# Which provider to use as fallback (default: none)
# OCR_FALLBACK_PROVIDER=hyperbolic

# Comma-separated list of Hyperbolic vision-language models
# HYPERBOLIC_OCR_MODELS=Qwen/Qwen2.5-VL-72B-Instruct,Qwen/Qwen2.5-VL-7B-Instruct

# Comma-separated list of OpenRouter models (default: google/gemini-2.5-flash-lite)
# OPENROUTER_OCR_MODELS=google/gemini-2.5-flash-lite

# HTTP-Referer header for OpenRouter (optional, default: URL)
# OPENROUTER_HTTP_REFERER=https://yourdomain.com

# App name shown in OpenRouter dashboard (optional)
# OPENROUTER_APP_NAME=instrumentskanner

# === Authentication ===

# Shared password for app login
# AUTH_PASSWORD=your_shared_password_here

# Secret for session tokens (use a long random string in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN_SECRET=your_secret_token_here

# === CORS ===

# Allowed CORS origins, comma-separated (optional)
# Netlify URLs are added automatically via URL, DEPLOY_PRIME_URL, DEPLOY_URL
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# === Usage statistics (Netlify Blobs) ===

# Required to store monthly OCR usage across function instances
# Find Site ID in Netlify dashboard -> Site settings -> General
# NETLIFY_SITE_ID=your_netlify_site_id_here

# Netlify personal access token (or deploy token with blobs access)
# NETLIFY_BLOBS_TOKEN=your_netlify_blobs_token_here
